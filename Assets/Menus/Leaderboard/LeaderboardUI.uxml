                    <ui:VisualElement class="ButtonFill"/>
                    <ui:VisualElement class="ButtonSheen"/>
                    <ui:Label text="Trade Show" class="ButtonText"/>
                </ui:Button>
                <ui:Button name="endlessMode" class="MainMenuButton" style="width: 275px; margin-right: 4px;">
                    <ui:VisualElement class="ButtonFill"/>
                    <ui:VisualElement class="ButtonSheen"/>
