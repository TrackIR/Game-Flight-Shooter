                </ui:Button>
                <ui:Button name="waveMode" class="MainMenuButton" style="width: 275px; margin-left: 36px;">
                    <ui:VisualElement class="ButtonFill"/>
                    <ui:VisualElement class="ButtonSheen"/>
                    <ui:Label text="Wave" class="ButtonText"/>
                </ui:Button>
            </ui:VisualElement>
